POSTGRES_USER=postgres
POSTGRES_PASSWORD=megapassword
POSTGRES_DB=mlflowdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
POSTGRES_LOCAL_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=${POSTGRES_URI}
MLFLOW_DEFAULT_ARTIFACT_ROOT=/mlflow_data/artifacts
MLFLOW_ARTIFACT_ROOT=./mlflow_data/artifacts

# Conexão ao R2 Storage
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ENDPOINT_URL=https://seu_id.r2.cloudflarestorage.com/
R2_BUCKET_NAME=mlops-course

# MLflow local connection (for scripts running on host)
MLFLOW_TRACKING_URI_LOCAL=http://localhost:5000

# Conexão ao Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_QUEUE=transcription_queue

BENTO_CONTAINER=whisper-service
TRANSCRIBE_URL=http://${BENTO_CONTAINER}:3000/transcribe